@echo off
chcp 65001 >nul 2>&1
setlocal EnableDelayedExpansion

echo ========================================
echo Install New UI Node.js Dependencies
echo ========================================
echo.

cd /d "%~dp0"

:: ============================
:: 基础检查
:: ============================
set "UI_DIR=%~dp0plugin\lora-scripts-ui-main\ui"

if not exist "%UI_DIR%\package.json" (
    echo [X] 未找到新前端文件，请确保 git submodule 已初始化。
    echo     请手动执行: git submodule update --init plugin/lora-scripts-ui-main
    pause
    exit /b 1
)

:: ============================
:: 检查 Node.js
:: ============================
echo [1/2] 检查 Node.js...
where node >nul 2>&1
if !errorlevel! neq 0 (
    echo [X] 未找到 Node.js，请先安装: https://nodejs.org/
    echo     推荐使用 LTS 版本 (18.x 或 20.x)
    pause
    exit /b 1
)

for /f "tokens=*" %%i in ('node -v') do set "NV=%%i"
echo   Node.js 版本: !NV!

:: 检查 npm
where npm >nul 2>&1
if !errorlevel! neq 0 (
    echo [X] 未找到 npm，请检查 Node.js 安装是否完整。
    pause
    exit /b 1
)

:: ============================
:: 安装依赖
:: ============================
echo.
echo [2/2] 安装前端依赖...
echo   目标目录: %UI_DIR%
echo   首次安装可能需要较长时间，请耐心等待...
echo.

cd /d "%UI_DIR%"

:: 使用淘宝镜像加速（可选）
:: npm config set registry https://registry.npmmirror.com

call npm install

if !errorlevel! neq 0 (
    echo.
    echo [X] npm install 失败。
    echo     尝试使用淘宝镜像重试...
    echo.
    call npm install --registry=https://registry.npmmirror.com
    if !errorlevel! neq 0 (
        echo.
        echo [X] 重试失败。请检查网络连接或手动运行:
        echo     cd "%UI_DIR%"
        echo     npm install
        pause
        exit /b 1
    )
)

echo.
echo [OK] 前端依赖安装完成。
echo.

exit /b 0
